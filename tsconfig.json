{
    "compilerOptions":  {
                            "target":  "ES2020",
                            "lib":  [
                                        "DOM",
                                        "DOM.Iterable",
                                        "ES2020"
                                    ],
                            "skipLibCheck":  true,
                            "esModuleInterop":  true,
                            "allowSyntheticDefaultImports":  true,
                            "strict":  false,
                            "module":  "ESNext",
                            "moduleResolution":  "Node",
                            "isolatedModules":  true,
                            "noEmit":  true,
                            "jsx":  "react-jsx",
                            "ignoreDeprecations":  "6.0"
                        },
    "include":  [
                    "src"
                ]
}
